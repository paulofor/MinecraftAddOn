# Cria um segmento decorativo de trilho maritimo 3x9 na direcao norte/sul.
# Use sobre a agua mirando para o inicio do trecho: /function estruturas/trilho_maritimo_segmento
setblock ~ ~ ~ digicomo:trilho_maritimo_luz
setblock ~ ~ ~1 digicomo:trilho_maritimo
setblock ~ ~ ~2 digicomo:trilho_maritimo
setblock ~ ~ ~3 digicomo:trilho_maritimo_luz
setblock ~ ~ ~4 digicomo:trilho_maritimo
setblock ~ ~ ~5 digicomo:trilho_maritimo
setblock ~ ~ ~6 digicomo:trilho_maritimo_luz
setblock ~ ~ ~7 digicomo:trilho_maritimo
setblock ~ ~ ~8 digicomo:trilho_maritimo
setblock ~1 ~ ~ digicomo:trilho_maritimo
setblock ~1 ~ ~1 digicomo:trilho_maritimo
setblock ~1 ~ ~2 digicomo:trilho_maritimo
setblock ~1 ~ ~3 digicomo:trilho_maritimo
setblock ~1 ~ ~4 digicomo:trilho_maritimo
setblock ~1 ~ ~5 digicomo:trilho_maritimo
setblock ~1 ~ ~6 digicomo:trilho_maritimo
setblock ~1 ~ ~7 digicomo:trilho_maritimo
setblock ~1 ~ ~8 digicomo:trilho_maritimo
setblock ~-1 ~ ~ digicomo:trilho_maritimo
setblock ~-1 ~ ~1 digicomo:trilho_maritimo
setblock ~-1 ~ ~2 digicomo:trilho_maritimo
setblock ~-1 ~ ~3 digicomo:trilho_maritimo
setblock ~-1 ~ ~4 digicomo:trilho_maritimo
setblock ~-1 ~ ~5 digicomo:trilho_maritimo
setblock ~-1 ~ ~6 digicomo:trilho_maritimo
setblock ~-1 ~ ~7 digicomo:trilho_maritimo
setblock ~-1 ~ ~8 digicomo:trilho_maritimo
say Segmento de Trilho Maritimo criado. Repita a funcao a cada 9 blocos para ampliar a linha sobre a agua.
